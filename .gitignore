# DACLE - Second Brain Knowledge Base
# Git Ignore File

# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*

# Temporary files
*.tmp
*.temp
*~
.#*

# Editor directories and files
.vscode/
.idea/
*.swp
*.swo
*.swn
.atom/

# Environment variables
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Dependencies
node_modules/
jspm_packages/

# Build outputs
dist/
build/
out/

# Database files (if local instances created)
*.db
*.sqlite
*.sqlite3

# API keys and secrets
secrets/
credentials/
*.key
*.pem

# Personal notes (if you want to keep some things private)
PRIVATE/
personal-notes/

# Backup files
*.bak
*.backup
*_backup

# Vector embeddings (can be regenerated)
embeddings/
*.vec

# Cache
.cache/
*.cache

# Python specific
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
htmlcov/
.tox/
.venv/
venv/
ENV/
env/
*.egg-info/
.installed.cfg
*.egg

# Jupyter Notebooks
.ipynb_checkpoints/

# Redis dump
dump.rdb

# Bot runtime files
bot.log
bot.pid
*.pid

# Temporary test files (but allow test suite in tests/ directory)
/test_*.py
/src/test_*.py
/scripts/test_*.py
scratch_*.py
# Note: tests/ directory test files ARE tracked
# Note: scripts/test_manual.py is tracked (proper script, not temporary)

# Temporary markdown files at root (docs should be in docs/)
/*_DIAGNOSIS.md
/*_NOW.md
/*_PLAN.md
/TEMP_*.md
/TODO_*.md
